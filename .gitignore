# Dependências
node_modules/

# Build / artefatos (contêm variáveis injetadas no bundle — NUNCA versionar em repo público)
build/
dist/
dist-ssr/
.vite/

# Variáveis de ambiente e segredos (valores reais só em máquina local ou painel do host)
.env
.env.local
.env.*.local
.env.development
.env.production
# Permite commitar apenas o template sem segredos:
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backups e exports locais (podem conter dados pessoais)
backup*.json
*-backup*.json
*.backup
exports/

# Testes / cobertura
coverage/
.nyc_output/

# SO
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
*.swp
*.swo
*~

